{
  "manifest_version": 3,
  "name": "DevLog Central – Multi-Tab Console & Error Aggregator",
  "version": "1.0.0",
  "description": "Multi-tab console aggregator",
  "permissions": ["tabs", "storage", "scripting", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "Open DevLog Central Panel",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "128": "icon128.png"
  }
}
